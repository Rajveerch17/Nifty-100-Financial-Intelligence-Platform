{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Streamlit Dashboard",
      "runtimeExecutable": "streamlit",
      "runtimeArgs": ["run", "src/dashboard/app.py"],
      "port": 8501
    },
    {
      "name": "FastAPI Server",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["src.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    }
  ]
}
